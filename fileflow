#!/bin/bash
# ──────────────────────────────────────────────────
# FileFlow — Tinder-style file sorter
# Usage: fileflow [open|start|stop|status]
# ──────────────────────────────────────────────────

PORT="${FILEFLOW_PORT:-5050}"

# Resolve symlinks to find the real install location
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
APP_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

LOG_FILE="/tmp/fileflow.log"
URL="http://localhost:$PORT"

# ── Port-based process detection (no PID file needed) ──

get_pid() {
  # Returns the PID of whatever is listening on $PORT, or empty
  lsof -ti ":$PORT" 2>/dev/null | head -1
}

is_running() {
  [ -n "$(get_pid)" ]
}

kill_port() {
  # Kill anything on the port — graceful first, force after 2s
  local pids
  pids=$(lsof -ti ":$PORT" 2>/dev/null)
  [ -z "$pids" ] && return 0

  kill $pids 2>/dev/null
  # Wait up to 2s for clean shutdown
  for i in 1 2 3 4; do
    sleep 0.5
    pids=$(lsof -ti ":$PORT" 2>/dev/null)
    [ -z "$pids" ] && return 0
  done
  # Force kill stragglers
  kill -9 $pids 2>/dev/null
  sleep 0.5
}

ensure_deps() {
  python3 -c "import flask" 2>/dev/null || {
    echo "  Installing dependencies..."
    pip3 install -q -r "$APP_DIR/requirements.txt" 2>/dev/null
  }
}

start_server() {
  ensure_deps

  if is_running; then
    echo "  FileFlow already running (PID $(get_pid)) on port $PORT"
    return 0
  fi

  nohup python3 "$APP_DIR/app.py" "$PORT" > "$LOG_FILE" 2>&1 &
  sleep 1

  if is_running; then
    echo "  FileFlow started (PID $(get_pid)) on port $PORT"
  else
    echo "  Failed to start — check $LOG_FILE"
    return 1
  fi
}

restart_server() {
  if is_running; then
    echo "  Stopping FileFlow (PID $(get_pid))..."
    kill_port
  fi
  start_server
}

stop_server() {
  if is_running; then
    local pid
    pid=$(get_pid)
    kill_port
    echo "  FileFlow stopped (was PID $pid)."
  else
    echo "  FileFlow is not running on port $PORT."
  fi
}

status() {
  if is_running; then
    echo "  FileFlow is running (PID $(get_pid)) on port $PORT"
    echo "  URL: $URL"
    echo "  Log: $LOG_FILE"
    echo ""
    curl -s "$URL/api/stats" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(f\"  Source:  {d['source_dir']}  ({d['source']} files)\")
    print(f\"  Inbox:   {d['inbox_dir']}  ({d['inbox']} files)\")
    print(f\"  Archive: {d['archive_dir']}  ({d['archive']} files)\")
except: pass
" 2>/dev/null
  else
    echo "  FileFlow is not running on port $PORT."
  fi
}

open_browser() {
  if command -v open &>/dev/null; then
    open "$URL"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$URL"
  elif command -v wslview &>/dev/null; then
    wslview "$URL"
  else
    echo "  Open $URL in your browser"
  fi
}

case "${1:-open}" in
  start)      start_server ;;
  stop)       stop_server ;;
  restart|r)  restart_server ;;
  status|s)   status ;;
  open|"")    start_server && open_browser ;;
  help|-h|--help)
    echo "FileFlow — Tinder-style file sorter"
    echo ""
    echo "Usage: fileflow [command]"
    echo ""
    echo "Commands:"
    echo "  (none)    Start server and open browser"
    echo "  start     Start server in background"
    echo "  stop      Stop the server"
    echo "  restart   Stop + start (clears port conflicts)"
    echo "  status    Show running state and folder info"
    echo "  help      Show this message"
    echo ""
    echo "Environment:"
    echo "  FILEFLOW_PORT   Server port (default: 5050)"
    echo ""
    echo "Config: ~/.fileflow.json"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'fileflow help' for usage."
    exit 1
    ;;
esac
